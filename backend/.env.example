NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Filled in on the Prisma schema step.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parahive?schema=public

ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Optional: first SYSADMIN is created by `npm run prisma:seed` only when all
# required values below are set and no SYSADMIN user exists yet.
SEED_SYSADMIN_LOGIN=
SEED_SYSADMIN_EMAIL=
SEED_SYSADMIN_PASSWORD=
SEED_SYSADMIN_FULL_NAME=
SEED_SYSADMIN_MUST_CHANGE_PASSWORD=false
